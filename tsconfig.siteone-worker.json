{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist-siteone-worker",
    "rootDir": ".",
    "sourceMap": true,
    "noEmit": false
  },
  "include": [
    "workers/siteone-pi-worker.ts",
    "lib/crawler/**/*.ts",
    "lib/jobs/siteone-rpc.ts",
    "lib/jobs/types.ts",
    "lib/config/siteone-worker-env.ts",
    "lib/supabase/database.types.ts"
  ],
  "exclude": ["node_modules", ".next", "dist-siteone-worker", "tests"]
}
