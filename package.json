{
  "name": "northstar-seo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build && npm run build:worker",
    "start": "node scripts/start-production.mjs",
    "start:production": "node scripts/start-production.mjs",
    "dev:worker": "tsx workers/crawl-worker.ts",
    "build:worker": "tsc -p tsconfig.worker.json",
    "start:worker": "node dist-worker/workers/crawl-worker.js",
    "dev:siteone-worker": "tsx workers/siteone-pi-worker.ts",
    "build:siteone-worker": "tsc -p tsconfig.siteone-worker.json",
    "start:siteone-worker": "node dist-siteone-worker/workers/siteone-pi-worker.js",
    "siteone:provision": "tsx scripts/provision-siteone-worker.ts",
    "siteone:enqueue": "tsx scripts/enqueue-siteone-crawl.ts",
    "monid:inspect:semrush": "tsx scripts/inspect-monid-semrush.ts",
    "monid:test:semrush": "tsx scripts/test-monid-semrush.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "supabase:init": "supabase init",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:lint": "supabase db lint",
    "supabase:types": "supabase gen types typescript --local --schema public > lib/supabase/database.types.ts"
  },
  "dependencies": {
    "@composio/core": "0.14.0",
    "@supabase/ssr": "0.12.3",
    "@supabase/supabase-js": "2.110.7",
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "cheerio": "1.2.0",
    "clsx": "latest",
    "fast-xml-parser": "5.10.1",
    "framer-motion": "latest",
    "ipaddr.js": "2.4.0",
    "lucide-react": "latest",
    "next": "latest",
    "p-limit": "7.3.0",
    "postcss": "8.5.10",
    "react": "latest",
    "react-dom": "latest",
    "robots-parser": "3.0.1",
    "tailwind-merge": "latest",
    "tailwindcss": "latest",
    "tldts": "7.4.9",
    "typescript": "5.9.3",
    "undici": "8.7.0",
    "zod": "latest"
  },
  "devDependencies": {
    "eslint": "9.38.0",
    "eslint-config-next": "latest",
    "supabase": "2.109.1",
    "tsx": "4.23.1",
    "vitest": "3.2.7"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  }
}
