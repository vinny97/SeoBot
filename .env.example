NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Explicitly true only for local visual testing. Production should set false.
NEXT_PUBLIC_DEMO_MODE=false
MONID_API_KEY=
MONID_API_BASE_URL=https://api.monid.ai
# JSON matching the inspected /trends_daily queryParams schema. Used only by the one-off test script.
MONID_TEST_QUERY_PARAMS_JSON=

# Server-only crawler worker credentials. Never expose or log this key.
SUPABASE_SECRET_KEY=
# Optional legacy fallback, read only by the central worker environment helper.
# SUPABASE_SERVICE_ROLE_KEY=

# Server-only publishing integration credentials. Never prefix these with NEXT_PUBLIC_.
INTEGRATION_ENCRYPTION_KEY=
COMPOSIO_API_KEY=
COMPOSIO_SHOPIFY_AUTH_CONFIG_ID=
COMPOSIO_GSC_AUTH_CONFIG_ID=ac_2d-b3WRSIFhr
# Direct Search Console OAuth. Register this redirect URL exactly in Google Cloud.
GOOGLE_GSC_CLIENT_ID=
GOOGLE_GSC_CLIENT_SECRET=
GOOGLE_GSC_REDIRECT_URI=http://localhost:3000/app/integrations/google-search-console/callback
GSC_TOKEN_ENCRYPTION_KEY=
CRAWLER_USER_AGENT=NorthstarCrawler/0.1
CRAWLER_CONTACT_URL=https://your-product-domain.example/crawler
CRAWLER_MAX_PAGES=50
CRAWLER_MAX_DEPTH=4
CRAWLER_FULL_SITE_MAX_PAGES=50000
CRAWLER_FULL_SITE_MAX_DEPTH=20
CRAWLER_CONCURRENCY=2
CRAWLER_REQUEST_DELAY_MS=750
CRAWLER_REQUEST_TIMEOUT_MS=15000
CRAWLER_MAX_HTML_BYTES=5000000
CRAWLER_MAX_SITEMAP_BYTES=10000000
CRAWLER_MAX_REDIRECTS=5
CRAWLER_WORKER_POLL_MS=3000
CRAWLER_JOB_LOCK_MINUTES=5
CRAWLER_MAX_DURATION_MS=900000
CRAWLER_FULL_SITE_MAX_DURATION_MS=21600000
CRAWLER_MANUAL_COOLDOWN_MINUTES=10
CRAWLER_DAILY_LIMIT=3
CRAWLER_LAB_ENABLED=false
CRAWLER_WORKER_OFFLINE_AFTER_SECONDS=60

# Raspberry Pi SiteOne worker. Keep these in /etc/seobot-siteone-worker.env on the Pi.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SITEONE_WORKER_TOKEN=
WORKER_ID=seobot-pi-worker-1
SITEONE_BINARY_PATH=/usr/bin/siteone-crawler
SITEONE_WORK_DIR=/DATA/seobot/crawls
SITEONE_MAX_PAGES=50
SITEONE_MAX_DEPTH=4
SITEONE_PROCESS_TIMEOUT_MINUTES=15
SITEONE_ALLOWED_PROJECT_IDS=
