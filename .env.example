# Public project identifiers are safe for browser use. Never expose the service role key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Keep demo mode on until Supabase is configured. Demo data is stored only in the browser.
NEXT_PUBLIC_DEMO_MODE=true
